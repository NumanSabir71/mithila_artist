<script>
  // Hero Carousel
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.dot');
  const track = document.getElementById('heroSlides');
  let currentIdx = 0;
  const total = slides.length;
  let autoTimer;

  function updateCarousel(index) {
    currentIdx = (index + total) % total;
    track.style.transform = `translateX(-${currentIdx * 100}%)`;
    slides.forEach((s, i) => {
      s.classList.toggle('active', i === currentIdx);
      dots[i]?.classList.toggle('active', i === currentIdx);
    });
    resetAuto();
  }

  function nextSlide() { updateCarousel(currentIdx + 1); }
  function prevSlide() { updateCarousel(currentIdx - 1); }
  function resetAuto() {
    if(autoTimer) clearInterval(autoTimer);
    autoTimer = setInterval(() => nextSlide(), 5500);
  }

  document.getElementById('nextSlide').addEventListener('click', nextSlide);
  document.getElementById('prevSlide').addEventListener('click', prevSlide);
  dots.forEach((dot, idx) => dot.addEventListener('click', () => updateCarousel(idx)));

  resetAuto();

  // Wishlist toggles
  document.querySelectorAll('.wish').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      btn.textContent = btn.textContent === '♡' ? '♥' : '♡';
      btn.style.color = btn.textContent === '♥' ? '#B5451B' : 'white';
    });
  });
</script>
